# Managed by: github.com/ManuelLerchner/manuellerchner.de-deploy
# Location on Pi: /srv/deploy/Caddyfile
# Symlinked from: /etc/caddy/Caddyfile

# ── Redirects ─────────────────────────────────────────────────────────────────

www.manuellerchner.de {
	redir https://{labels.1}.{labels.0}{uri} permanent
}

# ── Main website (static) ─────────────────────────────────────────────────────

manuellerchner.de {
	root * /srv/apps/Website/public
	encode gzip
	file_server
}

# ── Node services ─────────────────────────────────────────────────────────────

pi.manuellerchner.de {
	reverse_proxy localhost:3000
	encode gzip
}

api.manuellerchner.de {
	reverse_proxy localhost:4000
	encode gzip
}

moneyflow.manuellerchner.de {
	reverse_proxy localhost:3020
	encode gzip
}

restaurantapp.manuellerchner.de {
	reverse_proxy localhost:3019
	encode gzip
}

