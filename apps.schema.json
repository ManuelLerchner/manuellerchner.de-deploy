{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "manuellerchner.de deploy config",
  "type": "object",
  "required": [
    "apps"
  ],
  "additionalProperties": false,
  "properties": {
    "apps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/app"
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stop_pm2_processes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "redirects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "$ref": "#/$defs/domain"
          },
          "to": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    },
    "passthrough": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "domain",
          "proxy"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "$ref": "#/$defs/domain"
          },
          "proxy": {
            "type": "string",
            "minLength": 1
          },
          "tls": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    }
  },
  "$defs": {
    "domain": {
      "type": "string",
      "pattern": "^(?!-)[A-Za-z0-9-]+(\\.(?!-)[A-Za-z0-9-]+)+$"
    },
    "maybeNullString": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "piBuildLimits": {
      "type": "object",
      "required": [
        "cpu_quota",
        "memory_high",
        "memory_max",
        "memory_swap_max",
        "nice",
        "ionice_class",
        "ionice_level",
        "node_max_old_space_size",
        "npm_ci_foreground_scripts"
      ],
      "additionalProperties": false,
      "properties": {
        "cpu_quota": {
          "type": "string",
          "pattern": "^[1-9][0-9]*%$"
        },
        "memory_high": {
          "type": "string",
          "pattern": "^[1-9][0-9]*[KMG]$"
        },
        "memory_max": {
          "type": "string",
          "pattern": "^[1-9][0-9]*[KMG]$"
        },
        "memory_swap_max": {
          "const": 0
        },
        "nice": {
          "type": "integer",
          "minimum": 0,
          "maximum": 19
        },
        "ionice_class": {
          "const": 2
        },
        "ionice_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "node_max_old_space_size": {
          "type": "integer",
          "minimum": 256
        },
        "npm_ci_foreground_scripts": {
          "type": "boolean"
        }
      }
    },
    "app": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "name",
            "repo",
            "build",
            "type",
            "output",
            "domain",
            "deploy_path",
            "spa"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "repo": {
              "type": "string",
              "pattern": "^https://github\\.com/.+\\.git$"
            },
            "build": {
              "$ref": "#/$defs/maybeNullString"
            },
            "pi_build_limits": {
              "$ref": "#/$defs/piBuildLimits"
            },
            "type": {
              "const": "static"
            },
            "output": {
              "type": "string",
              "minLength": 1
            },
            "domain": {
              "$ref": "#/$defs/domain"
            },
            "deploy_path": {
              "type": "string",
              "minLength": 1
            },
            "spa": {
              "type": "boolean"
            },
            "env_file": {
              "type": "string",
              "minLength": 1
            },
            "env_note": {
              "type": "string",
              "minLength": 1
            },
            "post_deploy_cmd": {
              "type": "string",
              "minLength": 1
            },
            "data_file": {
              "type": "string",
              "minLength": 1
            },
            "data_note": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "required": [
            "name",
            "repo",
            "build",
            "type",
            "deploy_path",
            "pm2_name",
            "domain",
            "port"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "repo": {
              "type": "string",
              "pattern": "^https://github\\.com/.+\\.git$"
            },
            "build": {
              "$ref": "#/$defs/maybeNullString"
            },
            "pi_build_limits": {
              "$ref": "#/$defs/piBuildLimits"
            },
            "type": {
              "const": "service"
            },
            "deploy_path": {
              "type": "string",
              "minLength": 1
            },
            "pm2_name": {
              "type": "string",
              "minLength": 1
            },
            "domain": {
              "oneOf": [
                {
                  "$ref": "#/$defs/domain"
                },
                {
                  "type": "null"
                }
              ]
            },
            "port": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                {
                  "type": "null"
                }
              ]
            },
            "entry": {
              "type": "string",
              "minLength": 1
            },
            "start_cmd": {
              "type": "string",
              "minLength": 1
            },
            "env_file": {
              "type": "string",
              "minLength": 1
            },
            "env_note": {
              "type": "string",
              "minLength": 1
            },
            "post_deploy_cmd": {
              "type": "string",
              "minLength": 1
            },
            "data_file": {
              "type": "string",
              "minLength": 1
            },
            "data_note": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "anyOf": [
                {
                  "required": [
                    "entry"
                  ]
                },
                {
                  "required": [
                    "start_cmd"
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "object",
          "required": [
            "name",
            "repo",
            "type",
            "deploy_path",
            "domain",
            "port",
            "compose_file",
            "compose_project",
            "env_file",
            "env"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "repo": {
              "type": "string",
              "pattern": "^https://github\\.com/.+\\.git$"
            },
            "type": {
              "const": "compose"
            },
            "deploy_path": {
              "type": "string",
              "minLength": 1
            },
            "domain": {
              "$ref": "#/$defs/domain"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "compose_file": {
              "type": "string",
              "minLength": 1
            },
            "compose_overrides": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "compose_project": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "env_file": {
              "type": "string",
              "minLength": 1
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "env_note": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
